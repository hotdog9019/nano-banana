# ---------------------------------------------------------
# Общие правила игнорирования для репозитория студента
# ---------------------------------------------------------

# Системные файлы ОС
.DS_Store
Thumbs.db

# Конфигурации IDE/редакторов
.vscode/
.idea/
*.swp
*.swo

# Виртуальные окружения Python
.venv/
venv/
env/
ENV/
.conda/
.venv*/

# Кеши Python и скомпилированные файлы
__pycache__/
*.py[cod]
*$py.class

# Папки и файлы сборки/дистрибуции (если вдруг появятся)
build/
dist/
eggs/
*.egg-info/
.installed.cfg

# Кеши и артефакты тестов
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Журналы
*.log
logs/

# Кеши Jupyter Notebook
.ipynb_checkpoints

# Файлы окружения и конфигурации с потенциальными секретами
.env
*.env
.env.*
!.env.example

# Разное
*.tmp
*.bak
*.old



# pip/temp caches (local)
.pip-cache/
.tmp/
.tmp-pip/

# Datasets downloaded by notebooks
homeworks/datasets/

.gitignore_global
homeworks/.claude/
# HW10-11 datasets (keep out of git)
homeworks/HW10-11/data/

# HW13 Hugging Face caches/checkpoints (keep out of git)
homeworks/HW13/.hf/
homeworks/HW13/results/
homeworks/HW13/artifacts/hf/
